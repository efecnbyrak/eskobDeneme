generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Kullanici {
  id              Int       @id @default(autoincrement())
  email           String    @unique
  kullaniciAdi    String?   @unique
  telefon         String?
  sifreHash       String
  ad              String
  soyad           String
  avatarUrl       String?
  rol             Rol       @default(USER)
  emailOnay       Boolean   @default(false)
  plan            Plan      @default(UCRETSIZ)
  planBitisTarihi DateTime?
  olusturmaT      DateTime  @default(now())
  guncelleT       DateTime  @updatedAt

  sehir        String?
  ilce         String?
  ilgiAlanlari String[]

  // Mobil push bildirimi
  expoPushToken  String?
  cihazPlatformu String? // 'ios' | 'android' | 'web'
  pushIzni       Boolean @default(false)

  // KVKK / soft delete
  deletedAt DateTime?

  // E-posta değiştirme altyapısı (şimdilik disabled)
  bekleyenEmail String?
  emailKodHash  String?
  emailKodSon   DateTime?

  esnaf      Esnaf?
  oturumlar  Oturum[]
  favoriler  Favori[]
  randevular Randevu[]
  yorumlar   Yorum[]
  kvkkLoglari KvkkLog[]
  gezilenler  GezilenEsnaf[]

  @@index([deletedAt])
  @@map("kullaniciler")
}

enum Rol {
  SUPER_ADMIN
  ADMIN
  BUSINESS
  USER
}

enum Plan {
  UCRETSIZ
  STARTER
  PRO
}

model Esnaf {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  isletmeAdi  String
  aciklama    String?  @db.Text
  kategori    Kategori @relation(fields: [kategoriId], references: [id])
  kategoriId  Int
  kapakFoto   String?
  logoUrl     String?
  fotograflar String[]

  sehir  String
  ilce   String
  adres  String?
  enlem  Float?
  boylam Float?

  telefon   String?
  whatsapp  String?
  website   String?
  instagram String?
  facebook  String?
  tiktok    String?
  youtube   String?

  bildirimAyarlari Json?

  calismaS         Json?
  kategoriAyarlari Json?

  aktif              Boolean  @default(true)
  onaylı             Boolean  @default(false)
  bekleyenIsletmeAdi String?
  olusturmaT         DateTime @default(now())
  guncelleT  DateTime @updatedAt

  sahip         Kullanici    @relation(fields: [kullaniciId], references: [id])
  kullaniciId   Int          @unique
  hizmetler          Hizmet[]
  hizmetKategorileri HizmetKategorisi[]
  randevular         Randevu[]
  yorumlar           Yorum[]
  istatistikler      Istatistik[]
  favoriler          Favori[]
  gezilenler         GezilenEsnaf[]

  @@index([sehir, kategoriId])
  @@index([slug])
  @@index([aktif, onaylı])
  @@map("esnaflar")
}

model Kategori {
  id     Int     @id @default(autoincrement())
  ad     String  @unique
  slug   String  @unique
  ikon   String
  ikonUrl String?
  renk   String
  sira   Int     @default(0)

  ustKategoriId  Int?
  ustKategori    Kategori?  @relation("KategoriHiyerarsi", fields: [ustKategoriId], references: [id])
  altKategoriler Kategori[] @relation("KategoriHiyerarsi")

  esnaflar Esnaf[]

  @@map("kategoriler")
}

model HizmetKategorisi {
  id         Int      @id @default(autoincrement())
  ad         String
  sira       Int      @default(0)
  olusturmaT DateTime @default(now())

  esnaf      Esnaf    @relation(fields: [esnafId], references: [id], onDelete: Cascade)
  esnafId    Int

  ustId  Int?
  ust    HizmetKategorisi?  @relation("HizmetKatHiyerarsi", fields: [ustId], references: [id], onDelete: SetNull)
  altlar HizmetKategorisi[] @relation("HizmetKatHiyerarsi")

  hizmetler Hizmet[]

  @@index([esnafId])
  @@map("hizmet_kategorileri")
}

model Hizmet {
  id         Int      @id @default(autoincrement())
  ad         String
  aciklama   String?
  fiyat      Decimal  @db.Decimal(10, 2)
  sure       Int?
  kategori   String?

  hizmetKategorisiId Int?
  hizmetKategorisi   HizmetKategorisi? @relation(fields: [hizmetKategorisiId], references: [id], onDelete: SetNull)
  fotoUrl    String?
  aktif      Boolean  @default(true)
  sira       Int      @default(0)
  olusturmaT DateTime @default(now())

  esnaf      Esnaf     @relation(fields: [esnafId], references: [id], onDelete: Cascade)
  esnafId    Int
  randevular Randevu[]

  indirimYuzde     Int?
  indirimBaslangic DateTime?
  indirimBitis     DateTime?
  oncelik          Int      @default(0)
  oneCikan         Boolean  @default(false)
  onlineOdeme      Boolean  @default(false)
  minOnRezervasyon Int?
  maksKatilimci    Int      @default(1)
  etiketler        String[]

  @@index([esnafId, aktif])
  @@map("hizmetler")
}

model Randevu {
  id             Int          @id @default(autoincrement())
  tarih          DateTime
  sure           Int
  durum          RandevuDurum @default(BEKLIYOR)
  musteriAd      String
  musteriTelefon String
  musteriNot     String?
  olusturmaT     DateTime     @default(now())
  guncelleT      DateTime     @updatedAt

  esnaf       Esnaf      @relation(fields: [esnafId], references: [id])
  esnafId     Int
  hizmet      Hizmet?    @relation(fields: [hizmetId], references: [id])
  hizmetId    Int?
  kullanici   Kullanici? @relation(fields: [kullaniciId], references: [id])
  kullaniciId Int?

  @@index([esnafId, tarih])
  @@index([esnafId, tarih, durum])
  @@index([kullaniciId])
  @@map("randevular")
}

enum RandevuDurum {
  BEKLIYOR
  ONAYLANDI
  IPTAL
  TAMAMLANDI
}

model Yorum {
  id         Int      @id @default(autoincrement())
  puan       Int
  yorum      String?  @db.Text
  musteriAd  String
  yanitlar     String?  @db.Text
  onaylı       Boolean  @default(false)
  bildirildi   Boolean  @default(false)
  bildirimNot  String?
  olusturmaT   DateTime @default(now())

  esnaf       Esnaf      @relation(fields: [esnafId], references: [id])
  esnafId     Int
  kullanici   Kullanici? @relation(fields: [kullaniciId], references: [id])
  kullaniciId Int?

  @@index([kullaniciId])
  @@index([esnafId, onaylı])
  @@map("yorumlar")
}

model Oturum {
  id          Int       @id @default(autoincrement())
  token       String    @unique
  kullanici   Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  kullaniciId Int
  sonT        DateTime
  olusturmaT  DateTime  @default(now())

  @@map("oturumlar")
}

model Favori {
  id          Int       @id @default(autoincrement())
  kullanici   Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  kullaniciId Int
  esnaf       Esnaf     @relation(fields: [esnafId], references: [id], onDelete: Cascade)
  esnafId     Int
  olusturmaT  DateTime  @default(now())

  @@unique([kullaniciId, esnafId])
  @@index([kullaniciId])
  @@map("favoriler")
}

model Istatistik {
  id           Int      @id @default(autoincrement())
  tarih        DateTime @default(now()) @db.Date
  goruntulenme Int      @default(0)
  tiklanma     Int      @default(0)
  randevuSay   Int      @default(0)
  whatsappT    Int      @default(0)

  esnaf   Esnaf  @relation(fields: [esnafId], references: [id])
  esnafId Int

  @@unique([esnafId, tarih])
  @@map("istatistikler")
}

// KVKK uyumu için işlem audit log'u (Madde 7 — silme talebi vb.)
model KvkkLog {
  id          Int      @id @default(autoincrement())
  kullaniciId Int
  islem       String // 'SIL_TALEBI' | 'IHRACAT_TALEBI' | 'DUZELTME' | ...
  aciklama    String?  @db.Text
  ipAdres     String?
  userAgent   String?
  olusturmaT  DateTime @default(now())

  kullanici Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)

  @@index([kullaniciId, olusturmaT])
  @@index([islem, olusturmaT])
  @@map("kvkk_loglari")
}

model GezilenEsnaf {
  id          Int       @id @default(autoincrement())
  kullanici   Kullanici @relation(fields: [kullaniciId], references: [id], onDelete: Cascade)
  kullaniciId Int
  esnaf       Esnaf     @relation(fields: [esnafId], references: [id], onDelete: Cascade)
  esnafId     Int
  sonGorulmeT DateTime  @default(now())

  @@unique([kullaniciId, esnafId])
  @@index([kullaniciId, sonGorulmeT(sort: Desc)])
  @@map("gezilen_esnaflar")
}
